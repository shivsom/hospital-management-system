# ─────────────────────────────────────────────────────────────
# Hospital Management System - Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── MySQL Database ────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=hms
MYSQL_USER=hmsuser
MYSQL_PASSWORD=change_me_db_password

# ── Spring Boot Backend ───────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/hms?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=hmsuser
SPRING_DATASOURCE_PASSWORD=change_me_db_password

# JWT secret: generate with `openssl rand -base64 64`
JWT_SECRET=REPLACE_WITH_STRONG_BASE64_SECRET_MIN_512_BITS
JWT_EXPIRATION=86400000

# CORS: comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost

# AI service base URL (internal Docker network)
AI_SERVICE_URL=http://ai-service:8000

# Spring profiles: use 'prod' for production
SPRING_PROFILES_ACTIVE=prod

# ── AI Microservice ───────────────────────────────────────────
# Allowed CORS origins for AI service (internal only in prod)
AI_CORS_ORIGINS=http://nginx:80

# HuggingFace cache (mount as volume for model persistence)
HF_HOME=/app/.cache/huggingface

# ── Docker Hub (CI/CD) ────────────────────────────────────────
DOCKER_HUB_USERNAME=your_dockerhub_username
DOCKER_HUB_REPO=hms
